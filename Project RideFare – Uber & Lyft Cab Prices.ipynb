    {
      "cell_type": "code",
      "source": [
        "rides['hour'] = rides['time_stamp'].dt.hour\n",
        "weather['hour']  = weather['time_stamp'].dt.hour\n",
        "\n",
        "price_by_hour = rides.groupby('hour')['price'].mean().reset_index()\n",
        "\n",
        "temp_by_hour = weather.groupby('hour')['temp'].mean().reset_index()\n",
        "\n",
        "\n",
        "df_merged = pd.merge(price_by_hour, temp_by_hour, on='hour', how='inner')\n",
        "\n",
        "df_merged['temp_level'] = pd.qcut(df_merged['temp'], q=3, labels=['Baja', 'Media', 'Alta'])\n",
        "\n",
        "plt.figure(figsize=(8,6))\n",
        "\n",
        "sns.scatterplot(\n",
        "    data=df_merged,\n",
        "    x='hour',\n",
        "    y='price',\n",
        "    hue='temp_level',\n",
        "    palette='viridis',\n",
        "    s=90\n",
        ")\n",
        "\n",
        "sns.regplot(\n",
        "    data=df_merged,\n",
        "    x='hour',\n",
        "    y='price',\n",
        "    scatter=False,\n",
        "    color='black',\n",
        "    line_kws={'linewidth':2}\n",
        ")\n",
        "\n",
        "plt.title(\"Precio según Temperatura por Hora\")\n",
        "plt.xlabel(\"Hora del día\")\n",
        "plt.ylabel(\"Precio promedio\")\n",
        "plt.grid(alpha=0.3)\n",
        "\n",
        "plt.show()\n"
